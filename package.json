{
  "name": "argus",
  "version": "0.0.5",
  "displayName": "Argus",
  "description": "AI coding assistant powered by Claude",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "argus.openChat",
        "title": "Argus: Open Chat"
      },
      {
        "command": "argus.askSelection",
        "title": "Argus: Ask About Selection"
      },
      {
        "command": "argus.editSelection",
        "title": "Argus: Edit Selection with AI"
      },
      {
        "command": "argus.reviewSelection",
        "title": "Argus: Review Selection"
      },
      {
        "command": "argus.newSession",
        "title": "Argus: New Session"
      }
    ],
    "keybindings": [
      {
        "command": "argus.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "argus.askSelection",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "argus.askSelection",
          "when": "editorHasSelection",
          "group": "argus@1"
        },
        {
          "command": "argus.editSelection",
          "when": "editorHasSelection",
          "group": "argus@2"
        },
        {
          "command": "argus.reviewSelection",
          "when": "editorHasSelection",
          "group": "argus@3"
        }
      ]
    },
    "configuration": {
      "title": "Argus",
      "properties": {
        "argus.model": {
          "type": "string",
          "default": "claude-opus-4-6",
          "enum": [
            "claude-opus-4-6",
            "claude-sonnet-4-6",
            "claude-haiku-4-5"
          ],
          "description": "Claude model to use"
        },
        "argus.inlineCompletions.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable inline code completions (Copilot-style)"
        },
        "argus.inlineCompletions.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce delay (ms) for inline completions"
        },
        "argus.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Ask Argus' code lens above functions and classes"
        },
        "argus.bash.useIntegratedTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Run bash commands in VS Code integrated terminal (visible)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "argus",
          "title": "Argus",
          "icon": "media/argus-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:webview && npm run compile",
    "build:webview": "vite build --config webview/vite.config.ts",
    "watch:webview": "vite build --watch --config webview/vite.config.ts",
    "dev:webview": "vite --config webview/vite.dev.config.ts",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0"
  },
  "dependencies": {}
}