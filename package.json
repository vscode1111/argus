{
  "name": "argus",
  "version": "0.0.48",
  "displayName": "Argus",
  "description": "AI coding assistant powered by Claude",
  "license": "UNLICENSED",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/frontend/extension.js",
  "icon": "media/argus-icon.png",
  "scripts": {
    "vscode:prepublish": "npm run build && npm run compile",
    "build": "vite build --config webview/vite.config.ts",
    "watch": "vite build --watch --config webview/vite.config.ts",
    "dev": "node scripts/dev.js",
    "dev:frontend": "vite --config webview/vite.dev.config.ts",
    "dev:server": "tsx server/index.ts",
    "compile": "tsc -p ./",
    "watch:tsc": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "dev:stop": "node scripts/dev-stop.js",
    "test:e2e:install": "npx playwright install chromium",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "test:e2e:integration": "node node_modules/@playwright/test/cli.js test --project=integration --no-deps",
    "test:e2e:ui": "node node_modules/@playwright/test/cli.js test --ui",
    "test:e2e:debug": "node node_modules/@playwright/test/cli.js test --debug",
    "test:e2e:headed": "node node_modules/@playwright/test/cli.js test --headed",
    "test:e2e:report": "node node_modules/@playwright/test/cli.js show-report",
    "ctx:install": "node scripts/context-menu.js",
    "ctx:uninstall": "node scripts/context-menu.js --uninstall",
    "ext:package": "vsce package",
    "ext:install": "node scripts/ext-install.js",
    "ext:uninstall": "code.cmd --uninstall-extension local.argus"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^15.6.1",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "koffi": "^2.16.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "argus.openChat",
        "title": "Argus: Open Chat",
        "icon": "media/argus-icon.svg"
      },
      {
        "command": "argus.askSelection",
        "title": "Argus: Ask About Selection"
      },
      {
        "command": "argus.editSelection",
        "title": "Argus: Edit Selection with AI"
      },
      {
        "command": "argus.reviewSelection",
        "title": "Argus: Review Selection"
      },
      {
        "command": "argus.newSession",
        "title": "Argus: New Session"
      },
      {
        "command": "argus.sendPath",
        "title": "Send path to Argus",
        "icon": "media/argus-icon.svg"
      }
    ],
    "keybindings": [
      {
        "command": "argus.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "argus.askSelection",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "argus.openChat",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "argus.sendPath",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "argus.sendPath",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "command": "argus.askSelection",
          "when": "editorHasSelection",
          "group": "argus@1"
        },
        {
          "command": "argus.editSelection",
          "when": "editorHasSelection",
          "group": "argus@2"
        },
        {
          "command": "argus.reviewSelection",
          "when": "editorHasSelection",
          "group": "argus@3"
        }
      ]
    },
    "configuration": {
      "title": "Argus",
      "properties": {
        "argus.model": {
          "type": "string",
          "default": "claude-opus-4-6",
          "enum": [
            "claude-opus-4-6",
            "claude-sonnet-4-6",
            "claude-haiku-4-5"
          ],
          "description": "Claude model to use"
        },
        "argus.inlineCompletions.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable inline code completions (Copilot-style)"
        },
        "argus.inlineCompletions.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce delay (ms) for inline completions"
        },
        "argus.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Ask Argus' code lens above functions and classes"
        },
        "argus.bash.useIntegratedTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Run bash commands in VS Code integrated terminal (visible)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "argus",
          "title": "Argus",
          "icon": "media/argus-icon.svg"
        }
      ]
    }
  }
}